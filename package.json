{
  "name": "m5rcels-redeemer",
  "version": "1.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:cloudflare": "wrangler pages dev dist --compatibility-date=2026-06-16",
    "dev:vercel": "vercel dev",
    "build": "vite build && tsc --noEmit",
    "build:frontend": "vite build",
    "typecheck": "tsc --noEmit",
    "preview": "vite preview",
    "deploy:cloudflare": "npm run build && wrangler pages deploy dist",
    "deploy:vercel": "vercel deploy --prod"
  },
  "dependencies": {
    "@vercel/kv": "^3.0.0",
    "vite": "^7.3.5"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260616.1",
    "@types/node": "^24.13.2",
    "@vercel/node": "^5.8.17",
    "typescript": "^5.9.3",
    "wrangler": "^4.100.0"
  }
}
