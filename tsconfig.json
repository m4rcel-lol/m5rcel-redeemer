{
  "compilerOptions": {
    "target": "ES2022",
    "useDefineForClassFields": true,
    "module": "ESNext",
    "lib": ["ES2022", "DOM", "WebWorker"],
    "types": ["node", "@cloudflare/workers-types"],
    "skipLibCheck": true,
    "moduleResolution": "Bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "strict": true,
    "noEmit": true
  },
  "include": [
    "src/**/*.ts",
    "server/**/*.ts",
    "functions/**/*.ts",
    "api/**/*.ts",
    "vite.config.ts"
  ]
}
